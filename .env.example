# BaiLongma 环境变量模板（可选）
# 用法：复制本文件为 .env 后按需填写。所有变量均可留空，留空即使用代码默认值。
# 注意：主 LLM 的 Provider / API Key 不在这里配置，而是通过激活页
#       http://127.0.0.1:3721/activation 写入 config.json，与 .env 无关。
#       .env 已被 .gitignore 忽略，不会进版本库；本 .env.example 会进版本库作为文档。

# ---- 服务监听 ----
# 监听地址，默认 127.0.0.1（仅本机）。局域网访问改为 0.0.0.0
BAILONGMA_HOST=127.0.0.1
# 监听端口，默认 3721
BAILONGMA_PORT=3721
# 设为 1 允许局域网其它设备访问（需配合 BAILONGMA_HOST=0.0.0.0）
BAILONGMA_ALLOW_LAN=0

# ---- 数据与资源目录（高级，一般不用改） ----
# BAILONGMA_USER_DIR=/path/to/user/data
# BAILONGMA_RESOURCES_DIR=/path/to/resources
# BAILONGMA_PORTABLE_DIR=/path/to/portable

# ---- 网络代理 ----
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1
# 调试代理：BAILONGMA_DEBUG_NETWORK=1

# ---- 飞书（可选，机器人/群聊接入） ----
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# ---- 联网搜索（可选，按需填其一） ----
# SERPER_API_KEY=
# JINA_API_KEY=
# SEARXNG_URL=
# BRAVE_API_KEY=
# TAVILY_API_KEY=

# ---- 模型/厂商 Key（可选；多数走激活页配置，这里用于环境变量覆盖） ----
# DEEPSEEK_MODEL=
# MINIMAX_API_KEY=
# ARK_API_KEY=
# SEEDANCE_API_KEY=
# DOUBAO_TTS_API_KEY=
# DOUBAO_TTS_APP_ID=
# DOUBAO_TTS_ACCESS_KEY=
# DOUBAO_TTS_RESOURCE_ID=

# ---- 热点源（可选） ----
# TIANAPI_KEY=
# TIKHUB_TOKEN=
# HOTDATA_API_KEY=
# HOTSPOT_WEIBO_URL=
# HOTSPOT_WECHAT_URL=

# ---- 本地 embedding 镜像（默认 hf-mirror.com，无网也能跑） ----
# HF_ENDPOINT=https://hf-mirror.com
