{
  "name": "bailongma",
  "productName": "Bailongma",
  "version": "2.1.542",
  "description": "A continuously running digital consciousness framework",
  "type": "module",
  "main": "electron/main.cjs",
  "author": {
    "name": "xiaoyuanda666-ship-it"
  },
  "scripts": {
    "start": "chcp 65001 >nul && electron .",
    "start:lan": "powershell -ExecutionPolicy Bypass -File scripts/start-lan.ps1 app",
    "start:backend": "chcp 65001 >nul && node --env-file=.env src/index.js",
    "start:backend:lan": "powershell -ExecutionPolicy Bypass -File scripts/start-lan.ps1 backend",
    "dev": "chcp 65001 >nul && node --env-file=.env --watch src/index.js",
    "build": "node scripts/prebuild-clean.mjs && node scripts/prepare-playwright-browsers.mjs && node scripts/build-macos-speech.mjs && node ./node_modules/@electron/rebuild/lib/cli.js -f -w better-sqlite3 -v 33.4.11 && node ./node_modules/electron-builder/cli.js",
    "build:win": "node scripts/prebuild-clean.mjs && node scripts/prepare-playwright-browsers.mjs --platform=win32 --arch=x64 && node scripts/build-macos-speech.mjs && node ./node_modules/@electron/rebuild/lib/cli.js -f -w better-sqlite3 -v 33.4.11 && node ./node_modules/electron-builder/cli.js --win",
    "build:mac": "node scripts/build-mac.mjs",
    "build:mac:x64": "node scripts/build-mac.mjs x64",
    "build:mac:arm64": "node scripts/build-mac.mjs arm64",
    "publish": "node scripts/prebuild-clean.mjs && node scripts/prepare-playwright-browsers.mjs && node scripts/build-macos-speech.mjs && node ./node_modules/@electron/rebuild/lib/cli.js -f -w better-sqlite3 -v 33.4.11 && node ./node_modules/electron-builder/cli.js --publish always",
    "postinstall": "node ./node_modules/electron-builder/cli.js install-app-deps",
    "test:rule-context": "electron ./src/test-rule-context.js",
    "test:complex-task": "electron ./src/test-complex-task.js",
    "test:relevance": "electron ./src/test-relevance-selection.js",
    "test:section-gate": "node ./src/test-section-gate.js",
    "test:tick-policy": "node ./src/test-tick-policy.js",
    "test:failed-outbound-dedupe": "node ./src/test-failed-outbound-dedupe.js",
    "test:consciousness-loop": "node ./src/test-consciousness-loop.js",
    "test:runtime-managers": "node ./src/test-index-refactor-modules.js",
    "test:agent-skills": "node ./src/test-agent-skills.js",
    "test:tool-factory": "node ./src/test-tool-factory.js",
    "test:api-message-utf8": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:ELECTRON_RUN_AS_NODE='1'; .\\node_modules\\.bin\\electron.cmd .\\src\\test-api-message-utf8.js\"",
    "test:strict-evaluation": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:ELECTRON_RUN_AS_NODE='1'; .\\node_modules\\.bin\\electron.cmd .\\src\\test-strict-evaluation.js\"",
    "test:no-fake-detection": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:ELECTRON_RUN_AS_NODE='1'; .\\node_modules\\.bin\\electron.cmd .\\src\\test-no-fake-tool-detection.js\"",
    "test:config-upgrade": "node ./src/test-config-upgrade.js",
    "test:media-modules": "node ./src/test-media-modules.js",
    "test:db-schema-module": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:ELECTRON_RUN_AS_NODE='1'; .\\node_modules\\.bin\\electron.cmd .\\src\\test-db-schema-module.js\"",
    "test:voice-continuous": "node ./src/test-voice-continuous.js",
    "test:websocket-security": "node ./src/test-websocket-security.js",
    "test:web-read": "node ./src/test-web-read.js",
    "test:playwright-packaging": "node ./scripts/test-playwright-packaging.mjs",
    "test:browser-core": "node ./src/test-browser-session-manager.js && node ./src/test-browser-session-integration.js",
    "smoke:packaged-playwright": "node ./scripts/smoke-packaged-playwright.mjs",
    "repair:memories:dry": "electron ./scripts/repair-memory-quality.js",
    "repair:memories": "electron ./scripts/repair-memory-quality.js --apply",
    "probe:config-upgrade": "node ./scripts/probe-config-upgrade.mjs",
    "smoke:tools": "node scripts/smoke-tools.mjs",
    "smoke:tool-factory-web": "node scripts/smoke-tool-factory-web-e2e.mjs",
    "smoke:brain-ui": "node scripts/smoke-brain-ui.mjs",
    "smoke:social": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:ELECTRON_RUN_AS_NODE='1'; .\\node_modules\\.bin\\electron.cmd .\\scripts\\smoke-social.mjs\"",
    "smoke:feishu-ws": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$env:ELECTRON_RUN_AS_NODE='1'; .\\node_modules\\.bin\\electron.cmd .\\scripts\\smoke-feishu-ws.mjs\""
  },
  "dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "@larksuiteoapi/node-sdk": "^1.68.0",
    "better-sqlite3": "^12.8.0",
    "d3": "^7.9.0",
    "electron-updater": "^6.3.9",
    "openai": "^6.34.0",
    "playwright": "1.59.1",
    "playwright-core": "1.59.1",
    "sherpa-onnx-node": "^1.13.3",
    "undici": "^6.25.0",
    "wechat-ilink-client": "^0.1.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.xiaoyuanda.bailongma",
    "productName": "Bailongma",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "npmRebuild": false,
    "asar": {
      "smartUnpack": false
    },
    "asarUnpack": [
      "**/node_modules/better-sqlite3/build/Release/*.node",
      "**/node_modules/@huggingface/transformers/**",
      "**/node_modules/sharp/**",
      "**/node_modules/@img/sharp-*/**",
      "**/node_modules/onnxruntime-node/**",
      "**/node_modules/sherpa-onnx-node/**",
      "**/node_modules/sherpa-onnx-win-x64/**",
      "**/node_modules/sherpa-onnx-darwin-x64/**",
      "**/node_modules/sherpa-onnx-darwin-arm64/**",
      "build/native-speech-recognizer",
      "src/voice/**"
    ],
    "extraResources": [
      {
        "from": "build/playwright-browsers/${os}-${arch}",
        "to": "playwright-browsers",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "electron/**/*",
      "src/**/*",
      "skills/**/*",
      "scripts/seed-memories.js",
      "index.html",
      "dashboard.html",
      "brain.html",
      "brain-ui.html",
      "website.html",
      "systemPrompt.html",
      "activation.html",
      "focus-banner.html",
      "turn-trace.html",
      "build/icon.ico",
      "build/icon.icns",
      "build/icon.png",
      "build/icon-mac-cartoon.png",
      "build/native-speech-recognizer",
      "sandbox/**/*",
      "!sandbox/*-test-*/**",
      "music/**/*",
      "package.json",
      "!**/*.map",
      "!src/test-*",
      "!src/**/test-*",
      "!scripts/smoke-*.mjs",
      "!src/**/__pycache__/**",
      "!src/**/*.pyc",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,*.d.ts}",
      "!**/node_modules/.cache",
      "!**/.vscode",
      "!data/**/*"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "installerHeaderIcon": "build/installerHeaderIcon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/uninstallerSidebar.bmp",
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "shortcutName": "Bailongma"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Bailongma uses the microphone for voice input when you enable voice features.",
        "NSSpeechRecognitionUsageDescription": "Bailongma may use speech recognition for voice input features."
      },
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "xiaoyuanda666-ship-it",
        "repo": "BaiLongma",
        "releaseType": "release"
      }
    ]
  }
}
